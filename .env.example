# Copy to .env and fill in. Never commit .env.

# --- Service ---------------------------------------------------------------
# Required in production. Without it the service refuses to start when
# DEID_ENV=production, and falls back to a known-insecure dev secret otherwise.
DEID_JWT_SECRET=

# Fernet key for encrypting SSNs at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# In production this belongs in a KMS or secrets manager, not here.
DEID_FIELD_KEY=

DEID_ENV=development

# --- LLM redactor (evaluation only; never on the serving path) --------------
# Only needed for `deid eval --redactor llm`. The service never reads this.
ANTHROPIC_API_KEY=

# --- Frontend --------------------------------------------------------------
# Leave unset in development; Vite's proxy forwards /api to localhost:8000.
# VITE_API_URL=https://api.example.com
