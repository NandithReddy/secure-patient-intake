# Copy to `.env` (in this deploy/ folder) on the VPS and fill in.
# The .env file holds secrets — it is gitignored, never commit it.

# Generate each of these once with the command shown, then paste the result:
#   JWT secret:  openssl rand -hex 32
DEID_JWT_SECRET=
#   Field key (for encrypting SSNs):
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DEID_FIELD_KEY=

# Optional. Not needed with the Vercel proxy (requests reach the API
# same-origin). Leave blank unless a browser calls the backend IP directly.
DEID_CORS_ORIGINS=
