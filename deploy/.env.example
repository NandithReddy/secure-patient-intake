# Copy to `.env` (in this deploy/ folder) on the VPS and fill in.
# The .env file holds secrets — it is gitignored, never commit it.

# The domain that points at this VPS. Caddy gets HTTPS for it automatically.
BACKEND_DOMAIN=api.yourdomain.com

# Your Vercel site URL(s), comma-separated, no trailing slash. This is what the
# backend allows to call it. Fill this in AFTER you deploy the frontend.
DEID_CORS_ORIGINS=https://your-app.vercel.app

# Generate each of these once with the command shown, then paste the result:
#   JWT secret:  openssl rand -hex 32
DEID_JWT_SECRET=
#   Field key (for encrypting SSNs):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DEID_FIELD_KEY=
